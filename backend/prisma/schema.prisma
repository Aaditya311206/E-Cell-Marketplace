datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("USER") // We add roles like 'USER' or 'ADMIN' for authorization
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
